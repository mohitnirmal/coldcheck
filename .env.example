# Copy this file to .env and replace the token with the one from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace-this-with-your-token

# India time is UTC+5:30, which is 330 minutes.
HABITBOT_UTC_OFFSET_MINUTES=330
QUESTBOT_UTC_OFFSET_MINUTES=330

# Optional custom database paths.
HABITBOT_DB=habithero.db
QUESTBOT_DB=questbuddy.db
